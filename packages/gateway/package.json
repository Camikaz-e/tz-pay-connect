{
  "name": "@tz-pay-connect/gateway",
  "version": "0.1.0",
  "description": "Self-hostable REST API Gateway for TZ-Pay-Connect",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
